{
  "name": "@a11yscout/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./wcag": {
      "types": "./dist/wcag.d.ts",
      "import": "./dist/wcag.js",
      "require": "./dist/wcag.cjs"
    },
    "./sarif": {
      "types": "./dist/sarif.d.ts",
      "import": "./dist/sarif.js",
      "require": "./dist/sarif.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
